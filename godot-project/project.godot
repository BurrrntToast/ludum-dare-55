; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ludum dare 55"
run/main_scene="res://scenes/levels/level_1.tscn"
config/features=PackedStringArray("4.2", "GL Compatibility")
config/icon="res://resources/textures/icon.svg"

[autoload]

GlobalScript="*res://scripts/global script/global_script.tscn"
SoundManager="*res://scenes/sound manager/sound_manager.tscn"
TransitionManager="*res://scenes/transition manager/transition_manager.tscn"

[display]

window/size/viewport_width=160
window/size/viewport_height=160
window/size/window_width_override=640
window/size/window_height_override=640
window/stretch/mode="canvas_items"

[file_customization]

folder_colors={
"res://entities/": "green",
"res://exports/": "red",
"res://resources/": "purple",
"res://scenes/": "blue",
"res://scripts/": "yellow"
}

